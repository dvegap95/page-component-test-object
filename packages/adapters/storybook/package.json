{
  "name": "@pco/adapter-storybook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@pco/core": "workspace:*",
    "@pco/queries": "workspace:*",
    "@pco/react": "workspace:*"
  },
  "peerDependencies": {
    "@storybook/test": "^8.0.0",
    "storybook": "^8.0.0"
  },
  "devDependencies": {
    "@storybook/test": "^8.6.0",
    "rimraf": "^6.0.1",
    "storybook": "^8.6.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
