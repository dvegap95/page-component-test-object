    "vitest": "^2.0.0"
  },
  "devDependencies": {
    "@pco/msw": "workspace:*",
    "@testing-library/user-event": "^14.5.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
