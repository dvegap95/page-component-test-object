    "cypress": "^13.0.0 || ^14.0.0 || ^15.0.0"
  },
  "devDependencies": {
    "cypress": "^14.0.0",
    "@testing-library/cypress": "^10.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
